<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/color"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F4F6F8">

    <!-- BACK ICON -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="80dp"
        android:layout_height="30dp"
        android:src="@drawable/back_arrow"
        android:background="@android:color/transparent"
        android:layout_gravity="start"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>

    <!-- TOP SPACE -->
    <Space
        android:layout_width="wrap_content"
        android:layout_height="10dp"/>

    <!-- BMI IMAGE -->
    <ImageView
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_bmi"
        android:contentDescription="BMI Icon"
        android:layout_marginBottom="12dp"/>

    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BMI Calculator"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="5dp"/>

    <!-- SUBTITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Check your body mass index"
        android:textSize="15sp"
        android:textColor="#666666"
        android:layout_marginBottom="25dp"/>

    <!-- WEIGHT -->
    <EditText
        android:id="@+id/weight"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Enter Weight (kg)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="15dp"/>

    <!-- FEET -->
    <EditText
        android:id="@+id/feet"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Enter Height (feet)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="15dp"/>

    <!-- INCHES -->
    <EditText
        android:id="@+id/inches"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Enter Inches (optional)"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="20dp"/>

    <!-- BUTTON -->
    <Button
        android:id="@+id/btn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Calculate BMI"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="25dp"/>
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View BMI History"/>

    <!-- RESULT -->
    <TextView
        android:id="@+id/result"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Result Will Appear Here"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"/>


</LinearLayout>